{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event",
  "description": "Schema for a security or system event",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique identifier for the event"
    },
    "incident_id": {
      "type": "string",
      "description": "ID of the incident this event belongs to"
    },
    "scenario_id": {
      "type": "string",
      "description": "ID of the scenario context"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "malicious_action_executed",
        "alert_raised",
        "alert_investigation_started",
        "incident_confirmed",
        "alert_denied",
        "containment_initiated",
        "containment_failed",
        "containment_succeeded",
        "incident_ended"
      ],
      "description": "The type or category of the event"
    },
    "actor_type": {
      "type": "string",
      "enum": ["red_team","blue_team","system"],
      "description": "Type of actor performing the action"
    },
    "actor_id": {
      "type": "string",
      "description": "Unique ID of the actor"
    },
    "target_type": {
      "type": "string",
      "enum": ["host","service","account","alert"],
      "description": "Type of target being acted upon"
    },
    "target_id": {
      "type": "string",
      "description": "Unique ID of the target"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the event occurred"
    },
    "metadata": {
      "type": "object",
      "description": "Additional context-specific information"
    },
    "outcome": {
      "type": ["string", "null"],
      "enum": ["success", "failure", "partial", "detected", "blocked", "allowed", "unknown", null],
      "description": "The result or outcome of the event"
    }
  },
  "required": [
    "event_id",
    "incident_id",
    "scenario_id",
    "event_type",
    "actor_type",
    "target_type",
    "timestamp"
 ]

} 
