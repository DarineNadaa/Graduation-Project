# Watcher Agent — environment configuration
# Copy to .env and fill in SESSION_CODE before running.

# Analyst identity — used as actor_id in posted events
ANALYST_ID=analyst-1

# 6-character uppercase code generated by POST /session/watcher on red-team-backend
# The red-team operator creates this code and shares it with the analyst.
SESSION_CODE=

# Internal service URLs (correct for Docker Compose; change to localhost:PORT for local runs)
COORDINATOR_URL=http://red-team-backend:8000
BLUETEAM_URL=http://attense-app:8010
OLLAMA_URL=http://ollama:11434

OLLAMA_MODEL=llama3.2
BATCH_INTERVAL=30
AUDIT_LOG=/var/log/audit/audit.log
