# Build contexts for attense-app and blueteam-image now resolve from the
# repo root (they need to COPY from both AttensePortal/attense-app/ and the
# top-level blueteam/ in the same build). Docker reads .dockerignore from the
# context root, not from the Dockerfile's own directory, so this file must
# live here now — without it, secrets/, .env, and .git would be sent to the
# Docker daemon on every build.
.git
.gitignore
secrets/
.env
.env.local
.env.*.local

**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/

**/node_modules/
**/dist/
.vite/

.venv/
venv/
env/

.vscode/
.idea/
**/.DS_Store

*.md
*.docx
*.excalidraw
**/*.zip
